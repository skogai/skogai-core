{
  "name": "join-todos",
  "description": "Join an array of todo objects into a human-readable summary string with status indicators",
  "version": "1.0.0",
  "input": {
    "type": ["array", "object"],
    "description": "Array of todo objects [{content, status}] or object containing such array at path"
  },
  "args": {
    "path": {
      "type": "string",
      "required": false,
      "description": "Dot-separated path to the todos array. Omit if input is the array directly."
    },
    "separator": {
      "type": "string",
      "required": false,
      "description": "String to join items (default: ', ')"
    }
  },
  "output": {
    "type": "string",
    "description": "Human-readable string: 'Task one (completed), Task two (pending)'"
  },
  "examples": [
    {
      "description": "Join todo array directly",
      "input": [{"content": "Write tests", "status": "completed"}, {"content": "Deploy", "status": "pending"}],
      "args": {},
      "output": "Write tests (completed), Deploy (pending)"
    },
    {
      "description": "Join from nested path",
      "input": {"input": {"todos": [{"content": "Fix bug", "status": "in_progress"}]}},
      "args": {"path": "input.todos"},
      "output": "Fix bug (in_progress)"
    },
    {
      "description": "Custom separator",
      "input": [{"content": "A", "status": "done"}, {"content": "B", "status": "pending"}],
      "args": {"separator": " | "},
      "output": "A (done) | B (pending)"
    }
  ],
  "tags": ["todo", "join", "summary", "format", "status"]
}