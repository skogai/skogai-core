{
  "$id": "https://skog.ai/schemas/frontmatter.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skogai frontmatter",
  "type": "object",
  "required": ["type"],
  "properties": {
    "name": {
      "$ref": "defs.schema.json#/$defs/slug"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "$ref": "defs.schema.json#/$defs/type"
    },
    "variant": {
      "$ref": "defs.schema.json#/$defs/variant"
    },
    "lessonStatus": {
      "$ref": "defs.schema.json#/$defs/lessonStatus"
    },
    "version": {
      "type": ["integer", "string"],
      "minimum": 1
    },
    "permalink": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "$ref": "defs.schema.json#/$defs/tag"
      },
      "uniqueItems": true
    },
    "match": {
      "type": "object",
      "properties": {
        "keywords": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "required": ["keywords"],
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
