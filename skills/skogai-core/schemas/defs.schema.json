{
  "$id": "https://skog.ai/schemas/defs.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Shared schema definitions",
  "$defs": {
    "type": {
      "type": "string",
      "enum": [
        "skill",
        "router",
        "workflow",
        "reference",
        "template",
        "script",
        "lesson",
        "pattern",
        "principle",
        "decision",
        "list"
      ]
    },
    "variant": {
      "type": "string",
      "enum": [
        "skill",
        "agents",
        "claude",
        "simple-skill",
        "nested-router",
        "standalone",
        "knowledge"
      ]
    },
    "lessonStatus": {
      "type": "string",
      "enum": ["active", "deprecated"]
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "tag": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[-_:][a-z0-9]+)*$"
    },
    "xmlSectionName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "heading": {
      "type": "object",
      "required": ["level", "title"],
      "properties": {
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "anchor": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "link": {
      "type": "object",
      "required": ["kind", "target"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "wiki",
            "path",
            "heading",
            "url",
            "asset",
            "anchor",
            "origin"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "entryStatus": {
      "type": "string",
      "enum": [
        "open",
        "done",
        "complete",
        "in-progress",
        "delegated",
        "cancelled"
      ]
    },
    "decisionStatus": {
      "type": "string",
      "enum": ["proposed", "accepted", "rejected", "superseded", "deprecated"]
    },
    "listEntry": {
      "type": "object",
      "required": ["type", "entryStatus", "message"],
      "properties": {
        "type": {
          "const": "entry"
        },
        "EntryStatus": {
          "$ref": "#/$defs/entryStatus"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "origin": {
          "$ref": "#/$defs/link"
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        }
      },
      "additionalProperties": false
    },
    "xmlSection": {
      "type": "object",
      "required": ["kind", "name"],
      "properties": {
        "kind": {
          "const": "xml"
        },
        "name": {
          "$ref": "#/$defs/xmlSectionName"
        },
        "content": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "table": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "number", "boolean", "null"]
            }
          }
        }
      },
      "additionalProperties": false,
      "anyOf": [
        { "required": ["content"] },
        { "required": ["items"] },
        { "required": ["table"] }
      ]
    }
  }
}
