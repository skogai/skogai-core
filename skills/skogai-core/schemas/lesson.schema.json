{
  "$id": "https://skog.ai/schemas/lesson.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    { "$ref": "document.schema.json" },
    {
      "properties": {
        "type": { "const": "lesson" },
        "frontmatter": {
          "type": "object",
          "required": ["match", "lessonStatus", "version"],
          "properties": {
            "type": { "const": "lesson" },
            "lessonStatus": {
              "$ref": "defs.schema.json#/$defs/lessonStatus"
            },
            "version": {
              "type": "integer",
              "minimum": 1
            },
            "match": {
              "type": "object",
              "required": ["keywords"],
              "properties": {
                "keywords": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 },
                  "minItems": 1
                },
                "tools": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "headings": {
          "type": "array",
          "allOf": [
            {
              "contains": {
                "type": "object",
                "properties": {
                  "title": { "const": "rule" }
                },
                "required": ["title"]
              }
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "title": { "const": "context" }
                },
                "required": ["title"]
              }
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "title": { "const": "pattern" }
                },
                "required": ["title"]
              }
            }
          ]
        }
      },
      "required": ["type", "frontmatter"]
    }
  ]
}
