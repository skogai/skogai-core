{
  "name": "skogai-core",
  "$schema": "https://www.schemastore.org/claude-code-marketplace.json",
  "description": "core plugins for skogai",
  "owner": {
    "name": "skogix",
    "email": "emil@skogsund.se"
  },
  "metadata": {
    "pluginRoot": "./"
  },
  "plugins": [
    {
      "name": "skogai-tests",
      "source": "./tests",
      "version": "0.0.2",
      "description": "Bats testing skill and per-plugin test suites for skogai plugins (hooks + jq focus)",
      "category": "testing",
      "strict": false
    },
    {
      "name": "skogai-jq",
      "source": "./plugins/skogai-jq",
      "version": "0.0.2",
      "description": "Schema-driven jq/JSON transformation library",
      "category": "data",
      "strict": false
    },
    {
      "name": "skogai-hooks",
      "source": "./plugins/skogai-hooks",
      "version": "0.0.2",
      "description": "Reusable Claude Code lifecycle hooks (session, tool guards, stop gates)",
      "category": "automation",
      "strict": false
    }
  ]
}
